# ─── نسخ هذا الملف إلى `.env` وعدّل القيم (لا ترفع `.env` إلى Git) ───

# ■ على Railway (الإنتاج): يُحقن عادةً تلقائياً من خدمة Postgres
#   الاسم: DATABASE_URL
#   الشكل الداخلي مثل: postgres.railway.internal — يعمل فقط من داخل Railway

# ■ على جهازك (تطوير محلي): استخدم الرابط العام
#   من Railway: Postgres → Connect → Public Network → انسخ Connection URL
#   أو المتغير DATABASE_PUBLIC_URL إن وُجد في المشروع
#
# مثال (استبدل بالقيمة الحقيقية من لوحة Railway):
# DATABASE_URL="postgresql://postgres:PASSWORD@SHORT.proxy.rlwy.net:PORT/railway"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway?schema=public"

# ─── SEO / روابط الموقع ───
# دومين الموقع (يُستخدم في canonical, og:url, JSON-LD, sitemap)
VITE_PUBLIC_SITE_URL=https://victorianiraq.com
# أصل الـ API لو كان على نطاق مختلف (مثلاً Railway)
# VITE_PUBLIC_API_ORIGIN=https://your-app.up.railway.app

# اختياري: إذا كان الـ API على نطاق آخر
# VITE_API_BASE=https://your-app.up.railway.app
