generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  isSuperAdmin Boolean  @default(false)
  permissions  String[] @default([])
}

model Setting {
  key   String @id
  value String
}

model Category {
  id       String    @id @default(cuid())
  slug     String    @unique
  name     String
  nameAr   String
  image    String?
  products Product[]
}

model Product {
  id            String      @id @default(cuid())
  slug          String      @unique
  name          String
  nameAr        String
  description   String
  descriptionAr String
  price         Decimal     @db.Decimal(10, 2)
  salePrice     Decimal?    @db.Decimal(10, 2)
  images        String[]
  sizes         String[]
  stock         Int         @default(0)
  featured      Boolean     @default(false)
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
}

model Order {
  id             String      @id @default(cuid())
  createdAt      DateTime    @default(now())
  customerName   String
  email          String      @default("")
  phone          String
  address        String
  city           String
  province       String      @default("")
  landmark       String      @default("")
  notes          String?
  total          Decimal     @db.Decimal(10, 2)
  status         String      @default("pending")
  // كود الخصم المُطبَّق (لقطة)
  discountId     String?
  discount       Discount?   @relation(fields: [discountId], references: [id], onDelete: SetNull)
  discountCode   String?
  discountAmount Decimal     @default(0) @db.Decimal(10, 2)
  items          OrderItem[]
}

// أكواد الخصم — يُنشئها المشرف، تُطبَّق عند الدفع وتعدّل المجموع.
model Discount {
  id            String    @id @default(cuid())
  /// الكود الذي يدخله الزبون (مخزَّن بالأحرف الكبيرة، فريد)
  code          String    @unique
  /// اسم وصفي للمشرف (عربي)
  nameAr        String
  /// اسم وصفي بالإنجليزية (اختياري)
  nameEn        String    @default("")
  /// نوع الخصم: percent (نسبة٪) أو fixed (مبلغ ثابت بالدينار)
  type          String    @default("percent")
  /// قيمة الخصم: للنسبة 1..100، للمبلغ الثابت بالدينار العراقي
  value         Decimal   @db.Decimal(10, 2)
  /// الحد الأدنى لمجموع المنتجات قبل التوصيل ليُقبل الكود
  minOrderTotal Decimal?  @db.Decimal(10, 2)
  /// السقف الأقصى لمبلغ الخصم (يُستخدم مع نوع percent)
  maxDiscount   Decimal?  @db.Decimal(10, 2)
  /// مفعَّل / معطَّل
  enabled       Boolean   @default(true)
  /// الحد الأقصى لعدد مرات الاستخدام (null = غير محدود)
  usageLimit    Int?
  /// عدد الاستخدامات الحالية
  usageCount    Int       @default(0)
  /// تاريخ الانتهاء (null = بدون)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  orders        Order[]
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  quantity    Int
  size        String
  unitPrice   Decimal @db.Decimal(10, 2)
  productName String
}

// زوار الموقع — كل زائر يُعرَّف بـ visitorId يُولَّد في المتصفح ويحفظ في localStorage
// الزيارة المتكررة من نفس المتصفح تحدّث lastSeen فقط ولا تزيد العدّاد.
model Visitor {
  id        String   @id
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())
  visits    Int      @default(1)
  userAgent String?
  ip        String?
}

// آراء الزبائن — اسم + تقييم بالنجوم (1..5) + تعليق
model Review {
  id          String   @id @default(cuid())
  name        String
  rating      Int
  comment     String
  createdAt   DateTime @default(now())
  approved    Boolean  @default(true)
  /// رمز سري يُعاد للمتصفح مرة واحدة عند الإنشاء — لحذف التعليق من دون تسجيل دخول
  deleteToken String?  @unique
}

// اشتراك Web Push لجهاز/متصفح صاحب المتجر — يُرسل عليه إشعار عند طلب جديد
model PushSubscription {
  id          String   @id @default(cuid())
  endpoint    String   @unique
  p256dh      String
  auth        String
  adminEmail  String
  userAgent   String?
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())

  @@index([adminEmail])
}
